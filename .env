# ──────────────────────────────────────────────────────────────
#  ArogyaAi — Environment Variables  (copy to .env and fill in)
# ──────────────────────────────────────────────────────────────

# IBM Cloud API Key (from cloud.ibm.com → Manage → Access → API keys)
IBM_API_KEY=

# IBM Watsonx.ai Project ID (from watsonx.ai → Manage → General → Project ID)
IBM_PROJECT_ID=

# Watsonx.ai service URL  (region-specific)
# us-south : https://us-south.ml.cloud.ibm.com
# eu-de    : https://eu-de.ml.cloud.ibm.com
# eu-gb    : https://eu-gb.ml.cloud.ibm.com
# jp-tok   : https://jp-tok.ml.cloud.ibm.com
IBM_URL=https://us-south.ml.cloud.ibm.com

# Granite model to use (choose one):
# ibm/granite-13b-chat-v2       ← recommended
# ibm/granite-8b-code-instruct
# ibm/granite-3-8b-instruct
MODEL_ID=mistralai/mistral-small-3-1-24b-instruct-2503

# Flask settings
FLASK_SECRET_KEY=change-me-to-a-random-secret-string
FLASK_DEBUG=false
PORT=5000

